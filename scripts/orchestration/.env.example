# Anthropic auth — Claude Agent SDK
# Subscription OAuth is the preferred path. If you have a Claude Max/Pro
# subscription configured for OAuth via the Claude Code CLI, the SDK picks it
# up automatically and no env var is required here.
#
# API key fallback (set only if you do NOT use subscription OAuth):
# ANTHROPIC_API_KEY=

# Model selection
ORCHESTRATION_PRIMARY_MODEL=claude-opus-4-8
ORCHESTRATION_FALLBACK_MODEL=claude-sonnet-4-6
ORCHESTRATION_HAIKU_MODEL=claude-haiku-4-5-20251001

# Reasoning effort for the per-ticket session: low|medium|high|max|xhigh.
# "max" = deepest reasoning (highest token + rate-limit cost). Requires a
# model + account that support the chosen level (max needs Opus 4.6+/Sonnet 4.6).
ORCHESTRATION_EFFORT=max

# Slack outbound (incoming webhook to the chosen channel, e.g., #fleetco-loop)
SLACK_WEBHOOK_URL=

# Slack inbound (Socket Mode + Bot tokens; required for slash commands and AI fallback)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_NOTIFY_CHANNEL=#fleetco-loop

# Loop tuning
ORCHESTRATION_CI_POLL_TIMEOUT_MIN=45
ORCHESTRATION_RATE_LIMIT_MAX_RETRIES=3
ORCHESTRATION_RATE_LIMIT_BUFFER_SECONDS=60
ORCHESTRATION_AGENT_MAX_TURNS=200

# Repo paths (rarely needs override; defaults relative to scripts/orchestration/)
ORCHESTRATION_REPO_ROOT=../..
