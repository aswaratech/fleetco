# FleetCo production reverse proxy (ADR-0014 §2–§3).
#
# Mounted read-only into the caddy service (see docker-compose.prod.yml).
# Caddy terminates TLS for the single public hostname and serves FleetCo
# same-origin: the API owns /api/*, /auth/*, and /health*; the Next.js web
# admin serves everything else. Serving both under one origin is what makes
# the session cookie first-party and CORS trivial (ADR-0014 §2).
#
# $PUBLIC_DOMAIN is supplied by the container environment (compose passes it
# from the on-box .env). It is intentionally not defaulted, so a missing value
# fails loudly at boot rather than silently serving on the wrong host.

{$PUBLIC_DOMAIN} {
	# Automatic HTTPS via Let's Encrypt (ADR-0014 §3): Caddy provisions and
	# renews the certificate for $PUBLIC_DOMAIN with no manual steps. The ACME
	# account + certs persist in the caddy_data volume. The box must be
	# reachable on ports 80 + 443 for the ACME challenge to succeed.

	encode zstd gzip

	# Security headers (2026-07-02 audit, pre-deploy hardening). One central
	# block covering both the api and web upstreams — the reverse proxy is the
	# right single place for response-header policy on a same-origin deploy.
	#   - HSTS: the session-cookie-authenticated admin must never downgrade to
	#     plain HTTP after first contact (Caddy already redirects 80→443; HSTS
	#     removes the attackable first hop on return visits).
	#   - X-Frame-Options DENY: no surface here is ever legitimately framed;
	#     kills clickjacking outright.
	#   - nosniff: responses are served with correct types; never let a browser
	#     second-guess them.
	#   - Referrer-Policy: cross-origin requests (e.g. OSM tile fetches on map
	#     surfaces) get origin-only referrers; the URL path never leaks.
	#   - -Server: drop the server banner; no free fingerprinting.
	# A Content-Security-Policy is deliberately NOT set here: a meaningful CSP
	# for the Next.js app needs nonce wiring in the app itself (a naive policy
	# breaks Next's inline runtime scripts) — an app-level follow-up, not a
	# proxy-level header.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Same-origin split (ADR-0014 §2). better-auth is mounted at /auth/{*splat}
	# and the health probes live at the root (/health, /health/ready), both
	# outside the Next.js app — so all three prefixes route to the api.
	@api path /api/* /auth/* /health*
	handle @api {
		reverse_proxy api:3001
	}

	# Everything else is the Next.js web admin.
	handle {
		reverse_proxy web:3000
	}
}
