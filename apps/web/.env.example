# FleetCo admin web local environment.
# Copy this file to .env.local (which is gitignored) and fill in real
# values. Tier 1 secrets per ADR-0013 must never appear in any committed
# file. Tier 2/3 data per ADR-0013 must never be embedded in
# NEXT_PUBLIC_* env vars (they ship to the browser).

# URL of the FleetCo API. Ticket 10's better-auth login form will POST
# sign-in requests to this base. In local development this is the dev
# server from apps/api (default port 3001).
NEXT_PUBLIC_API_URL=http://localhost:3001
