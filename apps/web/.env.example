# FleetCo admin web local environment.
# Copy this file to .env.local (which is gitignored) and fill in real
# values. Tier 1 secrets per ADR-0013 must never appear in any committed
# file. Tier 2/3 data per ADR-0013 must never be embedded in
# NEXT_PUBLIC_* env vars (they ship to the browser).

# URL of the FleetCo API. The better-auth React client (src/lib/auth-client.ts)
# derives its baseURL as ${NEXT_PUBLIC_API_URL}/auth and the server-side
# session check (src/lib/session.ts) hits ${NEXT_PUBLIC_API_URL}/auth/get-session.
# In local development this is the dev server from apps/api (default port 3001;
# if you overrode apps/api/.env's PORT to dodge a port collision, update here too).
NEXT_PUBLIC_API_URL=http://localhost:3001
