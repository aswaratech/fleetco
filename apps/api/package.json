{
  "name": "@fleetco/api",
  "private": true,
  "version": "0.0.0",
  "description": "FleetCo API (NestJS). See CLAUDE.md, ADR-0018, ADR-0020.",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed-admin.ts",
    "db:create-user": "tsx scripts/create-user.ts",
    "auth:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1072.0",
    "@fleetco/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/sdk-trace-node": "~1.30.1",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^9.0.0",
    "@sentry/opentelemetry": "^9.47.1",
    "better-auth": "~1.6.11",
    "bullmq": "^5.78.0",
    "dotenv": "^17.0.0",
    "ioredis": "^5.0.0",
    "nestjs-pino": "^4.0.0",
    "pdfkit": "0.19.1",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "resend": "6.14.0",
    "rxjs": "^7.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.24",
    "@swc/core": "^1.15.40",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/pdfkit": "0.17.6",
    "pino-pretty": "^11.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.4"
  }
}
