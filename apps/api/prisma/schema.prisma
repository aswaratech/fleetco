// FleetCo Prisma schema. See apps/api/README.md for location rationale
// and ADR-0020 for the data-plane stack.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// Authentication models. Owned by apps/api/src/modules/auth/ per ADR-0001.
// Library: better-auth (ADR-0015). Integration shape: ADR-0021.
// Field shapes derived from @better-auth/core 1.6.11's getAuthTables.
// Tier annotations per ADR-0013 (Tier 1 = credentials/tokens, Tier 2 = PII).
// Triple-slash comments surface as JSDoc on the generated Prisma client.

model User {
  id              String    @id
  /// Tier 2 PII per ADR-0013 — excluded from default logging (pino redact covers *.email).
  email           String    @unique
  emailVerified   Boolean   @default(false)
  /// Tier 2 PII per ADR-0013 — admin display name.
  name            String
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
  accounts        Account[]
  vehiclesCreated Vehicle[] @relation("VehicleCreatedBy")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  /// Tier 1 per ADR-0013 — opaque session token; never logged (pino redact covers *.token).
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Tier 2 PII per ADR-0013 — captured for audit; excluded from default logging.
  ipAddress String?
  /// Tier 2 PII per ADR-0013 — captured for audit; excluded from default logging.
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  /// Tier 1 per ADR-0013 — provider access token (OAuth, future).
  accessToken           String?
  /// Tier 1 per ADR-0013 — provider refresh token (OAuth, future).
  refreshToken          String?
  /// Tier 1 per ADR-0013 — provider id token (OAuth, future).
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  /// Tier 1 per ADR-0013 — hashed credential. Never logged (pino redact covers *.password).
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  /// Tier 1 per ADR-0013 — verification token (password reset, email change, etc.).
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Vehicles module. Owned by apps/api/src/modules/vehicles/ per ADR-0001.
// First Phase 1 vertical slice per the roadmap; foundation aggregate for
// Trips per ADR-0003 (every downstream slice references Vehicle by id).
// Tier annotations per ADR-0013: vehicle records are Tier 3 (operational
// business data) — logged at the level of operational events but not at
// the level of full record content; access restricted to authenticated
// administrative users.

enum VehicleKind {
  TRUCK
  TIPPER
  EXCAVATOR
  LOADER
  GRADER
  OTHER

  @@map("vehicle_kind")
}

enum VehicleStatus {
  ACTIVE
  IN_MAINTENANCE
  RETIRED
  SOLD

  @@map("vehicle_status")
}

model Vehicle {
  id                 String        @id @default(cuid())
  /// Tier 3 per ADR-0013 — Nepali commercial plate (loose validation in
  /// Phase 1; tightened in a later slice). Unique across the fleet.
  registrationNumber String        @unique
  kind               VehicleKind
  /// Tier 3 per ADR-0013 — manufacturer (e.g., "Tata", "Mahindra").
  make               String
  /// Tier 3 per ADR-0013 — model designation (e.g., "LPK 2518").
  model              String
  /// Tier 3 per ADR-0013 — manufacture year.
  year               Int
  status             VehicleStatus @default(ACTIVE)
  /// Tier 3 per ADR-0013 — odometer at acquisition (kilometers). Baseline
  /// for lifetime distance tracking; defaults to 0 when the vehicle is
  /// new or the prior reading is unknown.
  odometerStartKm    Int           @default(0)
  /// Tier 3 per ADR-0013 — current odometer reading (kilometers).
  /// Updated by trip end events; tracked at vehicle level so reports
  /// can compute lifetime kilometers (current - start).
  odometerCurrentKm  Int           @default(0)
  /// Tier 3 per ADR-0013 — date the vehicle joined the fleet.
  acquiredAt         DateTime
  /// Tier 3 per ADR-0013 — date the vehicle left the fleet (retired or
  /// sold). Nullable; populated when status transitions to RETIRED or SOLD.
  retiredAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  /// References the User who created the record (ADR-0021 admin user).
  /// Audit field; restrict deletion of users with vehicles (Restrict).
  createdById        String
  createdBy          User          @relation("VehicleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([kind])
  @@index([createdById])
  @@map("vehicle")
}
