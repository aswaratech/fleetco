// FleetCo Prisma schema. See apps/api/README.md for location rationale
// and ADR-0020 for the data-plane stack.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// Authentication models. Owned by apps/api/src/modules/auth/ per ADR-0001.
// Library: better-auth (ADR-0015). Integration shape: ADR-0021.
// Field shapes derived from @better-auth/core 1.6.11's getAuthTables.
// Tier annotations per ADR-0013 (Tier 1 = credentials/tokens, Tier 2 = PII).
// Triple-slash comments surface as JSDoc on the generated Prisma client.

// Authorization roles per ADR-0028 (office-staff RBAC model). Two LIVE
// roles — ADMIN (the CEO/owner, the most-privileged human) and
// OFFICE_STAFF (operational data entry plus derived views) — plus DRIVER,
// which is reserved-but-undefined per ADR-0028 commitment 1: the enum
// names it so the role type and permission map accept a third role
// without rework, but it is granted no capabilities here; its permissions
// (almost entirely row-level) land with the driver-app slice. The role is
// stored on the better-auth-managed User and rides session.user.role so
// the RolesGuard reads it with no extra query (ADR-0028 commitments 2/3).
enum UserRole {
  ADMIN
  OFFICE_STAFF
  DRIVER

  @@map("user_role")
}

model User {
  id                      String            @id
  /// Tier 2 PII per ADR-0013 — excluded from default logging (pino redact covers *.email).
  email                   String            @unique
  emailVerified           Boolean           @default(false)
  /// Tier 2 PII per ADR-0013 — admin display name.
  name                    String
  image                   String?
  /// Tier 3 per ADR-0013 — authorization metadata, not a credential or PII; intentionally NOT redacted (a session's role is operational signal).
  role                    UserRole          @default(OFFICE_STAFF)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  sessions                Session[]
  accounts                Account[]
  vehiclesCreated         Vehicle[]         @relation("VehicleCreatedBy")
  driversCreated          Driver[]          @relation("DriverCreatedBy")
  tripsCreated            Trip[]            @relation("TripCreatedBy")
  customersCreated        Customer[]        @relation("CustomerCreatedBy")
  jobsCreated             Job[]             @relation("JobCreatedBy")
  fuelLogsCreated         FuelLog[]         @relation("FuelLogCreatedBy")
  expenseLogsCreated      ExpenseLog[]      @relation("ExpenseLogCreatedBy")
  gpsPingsCreated         GpsPing[]         @relation("GpsPingCreatedBy")
  geofencesCreated        Geofence[]        @relation("GeofenceCreatedBy")
  serviceSchedulesCreated ServiceSchedule[] @relation("ServiceScheduleCreatedBy")
  serviceRecordsCreated   ServiceRecord[]   @relation("ServiceRecordCreatedBy")
  /// The Driver this login identity is linked to, if any (ADR-0034 c4). A User
  /// with role DRIVER is linked 1:1 to a Driver row via Driver.userId.
  driver                  Driver?           @relation("DriverUser")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  /// Tier 1 per ADR-0013 — opaque session token; never logged (pino redact covers *.token).
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Tier 2 PII per ADR-0013 — captured for audit; excluded from default logging.
  ipAddress String?
  /// Tier 2 PII per ADR-0013 — captured for audit; excluded from default logging.
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  /// Tier 1 per ADR-0013 — provider access token (OAuth, future).
  accessToken           String?
  /// Tier 1 per ADR-0013 — provider refresh token (OAuth, future).
  refreshToken          String?
  /// Tier 1 per ADR-0013 — provider id token (OAuth, future).
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  /// Tier 1 per ADR-0013 — hashed credential. Never logged (pino redact covers *.password).
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  /// Tier 1 per ADR-0013 — verification token (password reset, email change, etc.).
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Vehicles module. Owned by apps/api/src/modules/vehicles/ per ADR-0001.
// First Phase 1 vertical slice per the roadmap; foundation aggregate for
// Trips per ADR-0003 (every downstream slice references Vehicle by id).
// Tier annotations per ADR-0013: vehicle records are Tier 3 (operational
// business data) — logged at the level of operational events but not at
// the level of full record content; access restricted to authenticated
// administrative users.

enum VehicleKind {
  TRUCK
  TIPPER
  EXCAVATOR
  LOADER
  GRADER
  OTHER

  @@map("vehicle_kind")
}

enum VehicleStatus {
  ACTIVE
  IN_MAINTENANCE
  RETIRED
  SOLD

  @@map("vehicle_status")
}

// Nepal vehicle-insurance categories. THIRD_PARTY satisfies the
// statutory minimum; COMPREHENSIVE covers own-damage in addition.
// The two-value enum reflects what Nepali insurers actually sell for
// heavy commercial vehicles in Phase 1 scope; extending with named
// add-ons (e.g., personal accident covers) is a non-breaking enum
// widen later if the operator needs to distinguish them.
enum InsuranceType {
  THIRD_PARTY
  COMPREHENSIVE

  @@map("insurance_type")
}

// Meter-type discriminator per ADR-0036 (engine-hours tracking). Says
// which meter(s) an asset has, INDEPENDENT of whether a reading has been
// captured yet (a brand-new excavator with no SMR recorded is still an
// ENGINE_HOURS asset — "tracks hours" and "has an hours reading yet" are
// different facts, the same reason the iter-14 compliance columns are
// nullable-but-present, ADR-0036 commitment 1). ODOMETER_KM is the
// default so the migration is backward-compatible: every existing vehicle
// keeps km-only behavior with no data change, and the operator flips
// equipment to ENGINE_HOURS (excavators, loaders, graders, generators,
// cranes — the earthmoving half whose wear tracks engine-hours, not
// kilometers) or BOTH (the rare truck-mounted crane: chassis on km, boom
// on hours) as they classify the fleet. An explicit column is preferred
// over deriving the meter from vehicle.kind (a chassis taxonomy with an
// OTHER escape hatch that cannot express BOTH) — see ADR-0036 Alternatives.
enum MeterType {
  ODOMETER_KM
  ENGINE_HOURS
  BOTH

  @@map("meter_type")
}

model Vehicle {
  id                 String        @id @default(cuid())
  /// Tier 3 per ADR-0013 — Nepali commercial plate (loose validation in
  /// Phase 1; tightened in a later slice). Unique across the fleet.
  registrationNumber String        @unique
  kind               VehicleKind
  /// Tier 3 per ADR-0013 — manufacturer (e.g., "Tata", "Mahindra").
  make               String
  /// Tier 3 per ADR-0013 — model designation (e.g., "LPK 2518").
  model              String
  /// Tier 3 per ADR-0013 — manufacture year.
  year               Int
  status             VehicleStatus @default(ACTIVE)
  /// Tier 3 per ADR-0013 — odometer at acquisition (kilometers). Baseline
  /// for lifetime distance tracking; defaults to 0 when the vehicle is
  /// new or the prior reading is unknown.
  odometerStartKm    Int           @default(0)
  /// Tier 3 per ADR-0013 — current odometer reading (kilometers).
  /// Updated by trip end events; tracked at vehicle level so reports
  /// can compute lifetime kilometers (current - start).
  odometerCurrentKm  Int           @default(0)

  // Engine-hours metering — ADR-0036. The earthmoving half of the fleet
  // (excavators, loaders, graders, generators, cranes) wears on
  // engine-hours, not kilometers. `meterType` says which meter(s) this
  // asset has; the two nullable columns below are the hours rotation of
  // odometerStartKm/odometerCurrentKm. Additive + backward-compatible:
  // meterType defaults to ODOMETER_KM and the hours columns are nullable,
  // so every existing km-only row is unchanged with no data migration
  // (the iter-14 nullable-compliance-columns posture).
  /// Tier 3 per ADR-0013 — which meter(s) this asset has (ADR-0036 c1):
  /// ODOMETER_KM (default; distance-metered trucks/tippers), ENGINE_HOURS
  /// (hour-metered equipment), or BOTH. Drives which reading the trip-stop
  /// UI prompts for and which stat the detail page shows.
  meterType          MeterType @default(ODOMETER_KM)
  /// Tier 3 per ADR-0013 — baseline hour-meter reading at acquisition,
  /// stored as integer TENTHS OF AN HOUR (deci-hours) — never a float
  /// (CLAUDE.md's never-floats rule, the FuelLog.litersMl integer-minor-
  /// units precedent extended to engine-hours): 1234.5 h stores as 12345,
  /// display divides by 10, cross-field math stays in integers. The hours
  /// rotation of odometerStartKm. Nullable: null is the honest value for a
  /// km-only asset (no hour-meter) and for an hour-metered asset registered
  /// before its SMR is keyed in (ADR-0036 c2).
  engineHoursStart   Int?
  /// Tier 3 per ADR-0013 — current hour-meter reading, integer TENTHS OF
  /// AN HOUR (deci-hours). The hours rotation of odometerCurrentKm:
  /// advanced by the Trip→Vehicle hours auto-update on a COMPLETED
  /// transition under the monotonic "once forward, stays forward" rule
  /// (ADR-0036 c5), the same rule as the odometer. VehiclesService.create
  /// defaults it to engineHoursStart ("current at acquisition equals
  /// start"). Nullable, same rationale as engineHoursStart.
  engineHoursCurrent Int?

  /// Tier 3 per ADR-0013 — date the vehicle joined the fleet.
  acquiredAt DateTime
  /// Tier 3 per ADR-0013 — date the vehicle left the fleet (retired or
  /// sold). Nullable; populated when status transitions to RETIRED or SOLD.
  retiredAt  DateTime?

  // Compliance metadata — Nepal-specific registration and document
  // tracking added in Phase 1 iter 14. All nullable: the Vehicle
  // aggregate shipped since iter 1 without these columns; existing
  // rows must remain readable, and operators are allowed to register
  // a vehicle before all its compliance docs are scanned in.
  // Phase 3 reminders will key off the three `*ExpiresAt` columns to
  // surface expiring-soon nudges.
  /// Tier 3 per ADR-0013 — Bluebook (नीलो किताब) registration number.
  bluebookNumber        String?
  /// Tier 3 per ADR-0013 — Bluebook expiry date.
  bluebookExpiresAt     DateTime?
  /// Tier 3 per ADR-0013 — name of the insurance carrier.
  insurer               String?
  /// Tier 3 per ADR-0013 — insurance policy number.
  insurancePolicyNumber String?
  /// Tier 3 per ADR-0013 — coverage type (THIRD_PARTY or COMPREHENSIVE).
  /// Single-row model: one active policy per vehicle.
  insuranceType         InsuranceType?
  /// Tier 3 per ADR-0013 — insurance expiry date.
  insuranceExpiresAt    DateTime?
  /// Tier 3 per ADR-0013 — route-permit number for the routes this
  /// vehicle is authorized to operate on.
  routePermitNumber     String?
  /// Tier 3 per ADR-0013 — route-permit expiry date.
  routePermitExpiresAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  /// References the User who created the record (ADR-0021 admin user).
  /// Audit field; restrict deletion of users with vehicles (Restrict).
  createdById String
  createdBy   User     @relation("VehicleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  trips       Trip[]       @relation("TripVehicle")
  fuelLogs    FuelLog[]
  expenseLogs ExpenseLog[]
  gpsPings    GpsPing[]

  // Preventive maintenance (ADR-0037). A vehicle is the anchor for many
  // concurrent service schedules (a 250-hour engine service, a 500-hour
  // hydraulic service, an annual inspection) and an unbounded, growing
  // history of completed service records. onDelete: Restrict on both FKs
  // (declared on the referencing models) means a vehicle with maintenance
  // history cannot be silently deleted — the EXISTING VehiclesService.delete
  // P2003 → 409 arm covers the new referencers with no change (ADR-0037 c1).
  serviceSchedules ServiceSchedule[]
  serviceRecords   ServiceRecord[]

  @@index([status])
  @@index([kind])
  @@index([createdById])
  @@map("vehicle")
}

// Drivers module. Owned by apps/api/src/modules/drivers/ per ADR-0001.
// Second Phase 1 vertical slice per the roadmap; a Driver is one of the
// two FK participants that the Trip aggregate references (the other is
// Vehicle, ADR-0003). Iter 6 ships the read path only; write path, the
// license-expiry workflow, and Driver→Vehicle assignment are deferred
// to later iters.
//
// Tier annotations per ADR-0013: driver records mix Tier 2 PII
// (fullName, phone, dateOfBirth, licenseNumber) with Tier 3 operational
// fields (status, hiredAt, licenseExpiresAt). The Tier 2 fields are
// excluded from default logging (pino redact in apps/api/src/app.module.ts
// already covers *.licenseNumber, *.phoneNumber, *.driverName — added
// pre-emptively before the Drivers slice existed).

// Nepal Department of Transport Management license categories. The
// four entries cover the heavy-construction-fleet use cases:
//   - LMV   light motor vehicle (cars/jeeps/vans for site supervisors)
//   - HMV   heavy motor vehicle (general heavy vehicle authorization)
//   - HTV   heavy transport vehicle (goods trucks and tippers — most of
//           the fleet's working drivers)
//   - HPMV  heavy passenger motor vehicle (buses and similar)
// Additional DoTM categories (LMV-NT, MGV, HGMV) are deliberately
// omitted in Phase 1 because they are uncommon in a heavy-construction
// fleet and adding them later is a non-breaking enum extension. The
// taxonomy is documented in docs/glossary.md.
enum LicenseClass {
  LMV
  HMV
  HTV
  HPMV

  @@map("license_class")
}

enum DriverStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED

  @@map("driver_status")
}

model Driver {
  id               String       @id @default(cuid())
  /// Tier 2 PII per ADR-0013 — driver's legal full name. Pino redact
  /// path `*.driverName` was added in iter 0 in anticipation of this
  /// slice; the field is still excluded from default logging.
  fullName         String
  /// Tier 2 PII per ADR-0013 — DoTM-issued license number. Unique
  /// across the fleet so a duplicate registration is rejected at the
  /// database layer (surfaces as P2002 → HTTP 409 via the service per
  /// docs/runbook/api-error-mapping.md). Pino redact path
  /// `*.licenseNumber` covers it.
  licenseNumber    String       @unique
  licenseClass     LicenseClass
  /// Tier 2 PII per ADR-0013 — phone number, stored loosely (no E.164
  /// normalization) because Nepali numbers come in many shapes and the
  /// fleet has both Nepali and occasional foreign numbers in practice.
  /// Pino redact path `*.phoneNumber` covers it.
  phone            String
  /// Tier 2 PII per ADR-0013 — optional date of birth. Stored as ISO/UTC
  /// per CLAUDE.md; BS-calendar rendering arrives with the future
  /// <NepaliDate> component on the web side.
  dateOfBirth      DateTime?
  /// Tier 3 per ADR-0013 — date the driver joined the fleet.
  hiredAt          DateTime
  /// Tier 3 per ADR-0013 — license expiry date. License-expiry alerting
  /// is a later-iter feature; the field is captured today so the
  /// alerting can be added without a schema change.
  licenseExpiresAt DateTime
  status           DriverStatus @default(ACTIVE)
  /// Tier 3 per ADR-0013 — date the driver was terminated. Nullable;
  /// populated when status transitions to TERMINATED. Mirrors
  /// Vehicle.retiredAt in shape and in the transition rule encoded by
  /// the service: status → TERMINATED auto-sets terminatedAt (to the
  /// client's value if provided, else now()); status transitioning out
  /// of TERMINATED clears it; explicit terminatedAt in PATCH always
  /// wins. (Iter 6 ships only the read path, but the column is in place
  /// so the iter-7 write path lands without a follow-up migration.)
  terminatedAt     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  /// References the User who created the record (ADR-0021 admin user).
  /// Audit field; restrict deletion of users with drivers (Restrict).
  createdById      String
  createdBy        User         @relation("DriverCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  /// Nullable FK to the User login identity for this driver (ADR-0034 c4).
  /// @unique so one login maps to at most one Driver. Nullable because a driver
  /// created before driver logins existed has no userId yet; an operator
  /// populates it when provisioning a login. The row-level "own data" scoping
  /// (D2) reads ownership through this link. onDelete: Restrict — a User with a
  /// linked Driver cannot be deleted out from under it.
  userId String? @unique
  user   User?   @relation("DriverUser", fields: [userId], references: [id], onDelete: Restrict)

  trips Trip[] @relation("TripDriver")

  @@index([status])
  @@index([licenseClass])
  @@index([createdById])
  @@map("driver")
}

// Trips module. Owned by apps/api/src/modules/trips/ per ADR-0001.
// Trip is the central aggregate of the FleetCo domain per ADR-0003:
// one Trip is one contiguous use of one Vehicle by one Driver, with
// start/end odometers and start/end timestamps. Vehicles and Drivers
// exist precisely so Trip can reference them by id.
//
// Iter 8 ships the read path only (schema + migration, list/detail
// API, list/detail UI); iter 9 layers the write path on top
// (POST/PATCH/DELETE + create/edit/cancel UI), the same staging
// pattern Vehicles iter-1/iter-2 and Drivers iter-6/iter-7 followed.
//
// Tier annotations per ADR-0013: trip records are Tier 3 (operational
// business data). `notes` is free-form operator commentary and is
// also Tier 3 — operators are expected not to enter PII there (and
// the future write-path UI's helper text will say so), but the field
// is not redacted from logs because over-redacting Tier 3 operational
// data hides the operational signal pino is meant to surface.
//
// FK delete policy: both vehicleId and driverId use onDelete: Restrict
// — we should not orphan trips by deleting a vehicle or a driver.
// This is the intentional contract: a Vehicle/Driver delete that
// would leave Trips dangling is blocked at the database. Today, the
// Vehicles and Drivers delete paths translate Prisma's P2002 unique-
// violation to HTTP 409 but do NOT yet translate P2003 (foreign-key
// restrict) — a delete attempted against a referenced row currently
// propagates as HTTP 500. The tech-debt entry "Vehicle/Driver delete
// when Trips reference them" tracks adding the P2003 → 409 mapping
// service-layer translation per the api-error-mapping runbook.

enum TripStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("trip_status")
}

model Trip {
  id               String     @id @default(cuid())
  /// FK to Vehicle. Indexed individually so list filters by vehicleId
  /// (the "trips for this vehicle" UI query) hit an index. onDelete:
  /// Restrict because trips reference vehicles by id throughout their
  /// lifetime; orphaning a trip from its vehicle would silently
  /// corrupt per-vehicle profit-and-loss calculations later. See the
  /// tech-debt entry on the cross-aggregate concern for the planned
  /// P2003 → 409 service-layer translation.
  vehicleId        String
  vehicle          Vehicle    @relation("TripVehicle", fields: [vehicleId], references: [id], onDelete: Restrict)
  /// FK to Driver. Same indexing and onDelete rationale as vehicleId.
  driverId         String
  driver           Driver     @relation("TripDriver", fields: [driverId], references: [id], onDelete: Restrict)
  status           TripStatus @default(PLANNED)
  /// Trip start time (when the driver leaves the depot / picks up the
  /// load). Nullable because a PLANNED trip has no start time yet —
  /// the iter-9 write path's status transition into IN_PROGRESS sets
  /// it. ISO/UTC per CLAUDE.md.
  startedAt        DateTime?
  /// Trip end time (when the driver returns the vehicle / drops the
  /// load). Nullable; only COMPLETED and CANCELLED trips carry an end
  /// time. ISO/UTC per CLAUDE.md.
  endedAt          DateTime?
  /// Odometer reading at the Vehicle when the trip started, in
  /// kilometers. Nullable because PLANNED trips have no start
  /// odometer reading yet. Integer per the Vehicle.odometer convention
  /// (no fractional kilometers at the trip-aggregate level; fractional
  /// distances belong on route-point data, a later slice).
  startOdometerKm  Int?
  /// Odometer reading at the Vehicle when the trip ended, in
  /// kilometers. Nullable until COMPLETED. The iter-9 write path's
  /// status transition into COMPLETED will also update
  /// Vehicle.odometerCurrentKm — explicitly out of scope for iter 8.
  endOdometerKm    Int?
  /// Engine-hours reading at the Vehicle when the trip STARTED, integer
  /// TENTHS OF AN HOUR (deci-hours) — the hours rotation of
  /// startOdometerKm (ADR-0036 c3), captured by the →IN_PROGRESS
  /// transition alongside startedAt. Nullable: a PLANNED trip has none
  /// yet, and a km-only (ODOMETER_KM) vehicle's trips never capture
  /// hours. Integer minor units, never a float (the litersMl precedent).
  startEngineHours Int?
  /// Engine-hours reading at the Vehicle when the trip ENDED, integer
  /// TENTHS OF AN HOUR (deci-hours) — the hours rotation of endOdometerKm,
  /// captured by the →COMPLETED transition alongside endedAt. On a
  /// COMPLETED transition, the same $transaction advances the referenced
  /// Vehicle.engineHoursCurrent to this value when the vehicle is
  /// hour-metered, under the monotonic "once forward" rule (ADR-0036 c5).
  /// Nullable until COMPLETED on an hour-metered vehicle.
  endEngineHours   Int?
  /// Free-form operator notes. Tier 3 operational data; not PII. The
  /// future write-path UI's helper text will direct operators not to
  /// enter PII here. Nullable; the empty case is null rather than "".
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  /// References the User who created the trip record (ADR-0021 admin
  /// user). Audit field; Restrict because the trip's audit chain
  /// should remain intact for the trip's lifetime.
  createdById      String
  createdBy        User       @relation("TripCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  fuelLogs    FuelLog[]
  expenseLogs ExpenseLog[]
  gpsPings    GpsPing[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([createdById])
  @@map("trip")
}

// Customers module. Owned by apps/api/src/modules/customers/ per ADR-0001.
// Third Phase 1 vertical slice per the roadmap. A Customer is a party
// who hires FleetCo's vehicles for jobs (see docs/glossary.md). Customer
// is master data — it does NOT FK into Trip directly; the future Jobs
// aggregate will reference Customer, and Trips will belong to Jobs.
//
// Iter 15 ships the read path only (schema + migration, list/detail
// API, list/detail UI, tests) — same staging pattern Vehicles iter-1
// / iter-2 and Drivers iter-6 / iter-7 followed. Iter 16 layers the
// write path (POST/PATCH/DELETE + create/edit/delete UI) on top,
// including the PAN-uniqueness P2002 → 409 mapping the runbook's
// api-error-mapping entry already anticipates.
//
// Tier annotations per ADR-0013: customer records mix Tier 2 PII
// (contactPerson, phone, email — all individual-person identifiers)
// with Tier 3 operational fields (name, panNumber, address, status).
// `name` is the business counterparty's name (company or individual);
// when the customer is an individual the name itself is personal,
// but on average the field carries business-counterparty data, so we
// treat it as Tier 3 with the caveat noted on the field. The pino
// redact paths in apps/api/src/app.module.ts cover *.email and
// *.phoneNumber; iter 15 adds *.contactPerson because the Tier 2 PII
// field is a person's name that does not match an existing redact path.

enum CustomerStatus {
  ACTIVE
  INACTIVE

  @@map("customer_status")
}

model Customer {
  id            String         @id @default(cuid())
  /// Tier 3 per ADR-0013 — business counterparty name (company or
  /// individual). When the customer is an individual person, this is
  /// arguably Tier 2 PII; on aggregate the field carries business
  /// names, so we annotate Tier 3 and rely on contactPerson for the
  /// always-individual PII case. A future tightening (e.g., a
  /// customerKind enum that splits BUSINESS vs INDIVIDUAL) can
  /// re-classify per-row if the calculus changes.
  name          String
  /// Tier 2 PII per ADR-0013 — the individual at the customer org
  /// FleetCo deals with day-to-day. Nullable: a small or one-off
  /// customer may not have a named contact distinct from the
  /// business itself. Pino redact path `*.contactPerson` covers it.
  contactPerson String?
  /// Tier 2 PII per ADR-0013 — phone number, stored loosely (no
  /// E.164 normalization) per the same CLAUDE.md "no PII-heavy
  /// regex" rationale that Driver.phone follows. Pino redact path
  /// `*.phoneNumber` covers it.
  phone         String
  /// Tier 2 PII per ADR-0013 — email address, loose validation
  /// (presence of `@`; CLAUDE.md forbids gold-plating). Nullable;
  /// not every customer org has a usable contact email. Pino redact
  /// path `*.email` covers it.
  email         String?
  /// Tier 3 per ADR-0013 — Nepal PAN (Permanent Account Number,
  /// the tax ID issued by the Inland Revenue Department).
  /// Unique-when-present: Postgres allows multiple NULLs under a
  /// UNIQUE index, so customers without a PAN do not collide. A
  /// duplicate PAN surfaces as Prisma P2002 → ConflictException →
  /// HTTP 409 per docs/runbook/api-error-mapping.md (the runbook
  /// already anticipates "Customers' PAN" in its P2002 table); the
  /// translation lives in CustomersService.create on the iter-16
  /// write path. PAN format validation beyond uniqueness (Nepal PAN
  /// is 9 digits) is deferred — tightening requires an ADR.
  panNumber     String?        @unique
  /// Tier 3 per ADR-0013 — billing or correspondence address. Free
  /// form, not parsed into street/city/postal-code sub-fields in
  /// Phase 1; the operator types what is on the paperwork. Nullable.
  address       String?
  status        CustomerStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  /// References the User who created the customer record (ADR-0021
  /// admin user). Audit field; Restrict because the customer's audit
  /// chain should remain intact for the customer's lifetime, and
  /// because the future Jobs aggregate will reference Customer by id.
  createdById   String
  createdBy     User           @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  // Iter 17: the Jobs aggregate references Customer by id. Job.customerId
  // uses onDelete: Restrict per ADR-0003, which is what flips the iter-16
  // forward-compatible P2003 → 409 branch on CustomersService.delete from
  // dead code to live code. The "Cannot delete customer: it is referenced
  // by other records." message the runbook commits to is now reachable
  // end-to-end via the apps/api/test/customers-delete-blocker.test.ts
  // integration test.
  jobs Job[]

  // Iter G1 (ADR-0030): CUSTOMER_SITE geofences reference Customer by id.
  // Geofence.customerId uses onDelete: Restrict per ADR-0030 c4, which is
  // covered for free by CustomersService.delete's EXISTING P2003 -> 409 arm
  // (no CustomersService change in the geofence program) — deleting a
  // customer that owns a customer-site fence returns a clean 409.
  geofences Geofence[]

  @@index([status])
  @@index([createdById])
  @@map("customer")
}

// Jobs module. Owned by apps/api/src/modules/jobs/ per ADR-0001.
// Fourth Phase 1 vertical slice per the roadmap. A Job is a unit of
// work FleetCo books for a Customer; one Customer can have many Jobs,
// and (in a later iter) one Job will have many Trips. Job sits between
// Customer (parent) and Trip (child) in the aggregate graph; this is
// the iter the Customer↔work relationship becomes navigable in the
// system, rather than implicit in operator memory.
//
// Iter 17 ships the read path only (schema + migration, list/detail
// API, list/detail UI, the iter-16 Customer-delete-blocker integration
// test going live). Iter 18 layers the write path on top
// (POST/PATCH/DELETE + the JOB-YYYY-NNNNN generator at the service
// layer + create/edit/delete UI). Same staging pattern Vehicles
// iter-1/iter-2, Drivers iter-6/iter-7, Trips iter-8/iter-9, and
// Customers iter-15/iter-16 followed.
//
// Tier annotations per ADR-0013: job records are Tier 3 (operational
// business data). `description` and `notes` are free-form operator
// commentary and are also Tier 3 — operators are expected not to
// enter PII there, but the fields are not redacted from logs because
// over-redacting Tier 3 operational data hides the operational signal
// pino is meant to surface. No new pino redact entries are added by
// iter 17 (the existing redact paths cover everything PII-shaped).
//
// FK delete policy: customerId uses onDelete: Restrict per ADR-0003 —
// we do not orphan jobs by deleting a customer. This is the contract
// that flips the iter-16 forward-compatible P2003 → 409 path on
// CustomersService.delete from dead code to live code; pinned by the
// new apps/api/test/customers-delete-blocker.test.ts integration test.
// createdById follows the same Restrict pattern as every other audit
// FK in the schema.

enum JobStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("job_status")
}

model Job {
  id                 String    @id @default(cuid())
  /// Human-readable job number in the form `JOB-YYYY-NNNNN` (e.g.
  /// `JOB-2026-00001`). Unique across the system so two jobs cannot
  /// share a number. The generator lives at the service layer in
  /// iter 18; for iter 17's read-path seed data and tests we
  /// hand-write a few canonical values. A duplicate jobNumber surfaces
  /// as Prisma P2002 → ConflictException → HTTP 409 with the
  /// `field: "jobNumber"` body shape per docs/runbook/api-error-mapping.md
  /// (mirror of Customers' PAN-conflict shape from iter 16); the
  /// translation will land in JobsService.create on the iter-18 write
  /// path.
  jobNumber          String    @unique
  /// FK to Customer. Indexed individually so list filters by customerId
  /// (the "jobs for this customer" UI query) hit an index. onDelete:
  /// Restrict per ADR-0003 — orphaning a job from its customer would
  /// silently corrupt per-customer billing later. This FK is the
  /// reason CustomersService.delete's P2003 → 409 branch becomes live
  /// in iter 17.
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  /// Tier 3 per ADR-0013 — free-form description of the work to be
  /// performed (e.g. "Haul aggregate from Kalimati to Pokhara site").
  /// Operators type the scope-of-work in plain text; structured
  /// breakdowns are a Phase 2+ concern. ≤2048 chars enforced at the
  /// schema/zod layer.
  description        String
  status             JobStatus @default(PLANNED)
  /// Planned start date (when the customer expects work to begin).
  /// Nullable because a job can be booked before a firm date is set.
  /// ISO/UTC per CLAUDE.md; BS-calendar rendering lands with the
  /// future <NepaliDate> component per DESIGN.md.
  scheduledStartDate DateTime?
  /// Planned end date. Same nullability rationale as
  /// scheduledStartDate; the cross-field rule "end >= start" arrives
  /// with the iter-18 write path's CreateJobSchema/UpdateJobSchema
  /// superRefine, not at the database layer.
  scheduledEndDate   DateTime?
  /// Actual start date (when work actually began). Nullable until
  /// status transitions into IN_PROGRESS via the iter-18 write path;
  /// today (read-only) it is whatever the seed data put there.
  actualStartDate    DateTime?
  /// Actual end date (when work actually completed). Nullable until
  /// status transitions into COMPLETED via the iter-18 write path.
  actualEndDate      DateTime?
  /// Free-form operator notes. Tier 3 operational data; not PII. The
  /// future write-path UI's helper text will direct operators not to
  /// enter PII here. Nullable; the empty case is null rather than "".
  /// ≤4096 chars enforced at the schema/zod layer.
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  /// References the User who created the job record (ADR-0021 admin
  /// user). Audit field; Restrict because the job's audit chain
  /// should remain intact for the job's lifetime.
  createdById        String
  createdBy          User      @relation("JobCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([customerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([createdById])
  @@map("job")
}

// Fuel logs module. Owned by apps/api/src/modules/fuel-logs/ per
// ADR-0001. Sixth Phase 1 vertical slice per the roadmap. A FuelLog is
// a record of fuel dispensed for a vehicle on a specific date —
// either at a depot top-up between jobs (no tripId) or as part of a
// specific trip (tripId set). The aggregate sits downstream of
// Vehicles and Trips and is the first money-bearing row in the
// system, so it is also the first to exercise CLAUDE.md's
// money-as-integer-minor-units rule end-to-end (paisa columns + the
// derived totalCostPaisa).
//
// Iter 19 ships the read path only (schema + migration, list/detail
// API, list/detail UI). Iter 20 layers the write path on top
// (POST/PATCH/DELETE + the write-time totalCostPaisa derivation +
// create/edit/delete UI). Same staging pattern Vehicles iter-1/iter-2,
// Drivers iter-6/iter-7, Trips iter-8/iter-9, Customers iter-15/iter-16,
// and Jobs iter-17/iter-18 followed.
//
// Tier annotations per ADR-0013: fuel-log records are Tier 1
// (operational data). `station` (vendor / fuel-station name) and
// `notes` (free-form operator commentary) are also Tier 1 — they are
// expected to carry operational data (vendor identity, paper-receipt
// references, fill remarks like "rain delayed dispatch") rather than
// PII. If the operator starts using `notes` for contact information,
// the redact list under ADR-0013 may need a follow-up entry; the
// glossary entry for "Fuel log" surfaces that contingency. No new pino
// redact entries are added by iter 19.
//
// FK delete policy:
//   - vehicleId — onDelete: Restrict per ADR-0003: deleting a vehicle
//     that has any fuel log is blocked at the DB (Postgres 23503 /
//     Prisma P2003), mapped to HTTP 409 in the iter-20 write path the
//     same way Customers' P2003 → 409 path was wired forward in iter 16.
//   - tripId — nullable, onDelete: Restrict: a fuel log MAY exist
//     without a trip (a depot top-up between jobs is the canonical
//     case) but if it points at one, that linkage cannot be silently
//     orphaned. Restricting a trip delete keeps per-trip fuel costs
//     intact for future profit-and-loss reporting.
//   - createdById — onDelete: Restrict, same audit-chain rationale as
//     every other createdBy FK in the schema.

model FuelLog {
  id                 String   @id @default(cuid())
  /// FK to Vehicle. Indexed individually so list filters by vehicleId
  /// (the "fuel for this vehicle" UI query, exposed in the iter-19
  /// list toolbar) hit an index. onDelete: Restrict per ADR-0003 —
  /// orphaning a fuel log from its vehicle would silently corrupt
  /// per-vehicle fuel-efficiency reporting later.
  vehicleId          String
  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  /// Nullable FK to Trip. A fuel log may or may not be tied to a
  /// specific trip — a top-up at the depot between jobs is the
  /// canonical "no trip" case. When set, onDelete: Restrict protects
  /// the linkage exactly as it protects vehicleId, so a trip delete
  /// cannot silently break per-trip cost reporting.
  tripId             String?
  trip               Trip?    @relation(fields: [tripId], references: [id], onDelete: Restrict)
  /// When the fuel was dispensed (UTC). Indexed `(date desc)` for the
  /// default list sort ("most recent fills first"). ISO/UTC per
  /// CLAUDE.md; BS-calendar rendering arrives with the future
  /// <NepaliDate> component.
  date               DateTime
  /// Liters stored as INTEGER MILLILITERS to mirror the project-wide
  /// money-as-integer-minor-units rule from CLAUDE.md. Never use Float
  /// or Decimal for fuel quantity — the same precision-loss argument
  /// CLAUDE.md makes for money applies to fuel quantity. Display
  /// divides by 1000 (e.g., 12345 → "12.345 L"). The unit-convention
  /// rationale is documented in the glossary entry for "Fuel log".
  litersMl           Int
  /// Price per liter in paisa (1 NPR = 100 paisa). Always integer
  /// minor units per CLAUDE.md. The display formatter renders e.g.
  /// 11050 paisa as "Rs. 110.50".
  pricePerLiterPaisa Int
  /// Total cost in paisa. DERIVED at write time as:
  ///     (litersMl * pricePerLiterPaisa) / 1000
  /// and stored so read endpoints do not recompute on every fetch.
  /// The iter-20 write path is responsible for the derivation; the
  /// iter-19 read path treats this column as authoritative for the
  /// amount the operator entered. The PATCH schema in iter 20 will
  /// reject this field via `.strict()` so it cannot drift from its
  /// derived value.
  totalCostPaisa     Int
  /// Optional odometer reading at fill time (kilometers — same unit
  /// as Vehicle.odometerCurrentKm). Nullable because not every fill
  /// captures a reading; when present, it's an additional anchor for
  /// the per-vehicle km/L reports a future iter ships.
  odometerReadingKm  Int?
  /// Vendor / fuel-station name (e.g., "NOC Naxal"). Nullable. Tier 1
  /// operational data — not PII per the glossary's caveat.
  station            String?
  /// Optional paper-receipt identifier. Nullable; not every fill has
  /// a receipt scan and the operator may key only the totals.
  receiptNumber      String?
  /// Free-text notes. Tier 1 operational data today (see the model
  /// comment above for the contingency note). Nullable; the empty
  /// case is null rather than "".
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  /// References the User who created the fuel-log record (ADR-0021
  /// admin user). Audit field; Restrict because the fuel-log's audit
  /// chain should remain intact for the row's lifetime.
  createdById        String
  createdBy          User     @relation("FuelLogCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([vehicleId])
  @@index([tripId])
  @@index([date(sort: Desc)])
  @@index([createdById])
  @@map("fuel_log")
}

// Expense logs module. Owned by apps/api/src/modules/expense-logs/ per
// ADR-0001. Seventh Phase 1 vertical slice per the roadmap. An
// ExpenseLog is a record of a non-fuel monetary outflow attributable
// to fleet operations — a tyre change, a toll payment, a parking
// charge, a quarterly insurance premium, a traffic fine. It is the
// second money-bearing aggregate (FuelLog is the first) and so reuses
// the integer-paisa convention from CLAUDE.md §"Money & units" rather
// than introducing a parallel "amount as decimal" path.
//
// Iter 21 ships the read path only (schema + migration, list/detail
// API, list/detail UI, tests). Iter 22 layers the write path on top
// (POST/PATCH/DELETE + create/edit/delete UI). Same staging pattern
// Vehicles iter-1/iter-2, Drivers iter-6/iter-7, Trips iter-8/iter-9,
// Customers iter-15/iter-16, Jobs iter-17/iter-18, and Fuel logs
// iter-19/iter-20 followed.
//
// Tier annotations per ADR-0013: expense-log records are Tier 1
// (operational data carrying money). `vendor` (the shop / mechanic /
// toll booth name), `receiptNumber`, and `notes` are all low-Tier —
// they carry operational data (vendor identity, paper-receipt
// references, "tyre rotated front-left" remarks) rather than PII or
// auth secrets. If operators start using `notes` for contact
// information, the redact list under ADR-0013 may need a follow-up
// entry; the glossary entry surfaces that contingency. No new pino
// redact entries are added by iter 21.
//
// FK delete policy:
//   - vehicleId — NULLABLE, onDelete: Restrict per ADR-0003. The
//     nullability is the key design difference from FuelLog: an
//     expense like the company's quarterly insurance premium is not
//     attributable to one vehicle, and the CEO records it here
//     rather than in a separate "company expense" table. A nullable
//     vehicleId lets the same endpoint serve both the per-vehicle
//     cost-report query (`?vehicleId=<id>`) and the global expense
//     feed (no filter). The iter-23 cost report will treat null
//     vehicleId as a separate bucket. When set, Restrict prevents a
//     vehicle delete from orphaning expense-history rows.
//   - tripId — NULLABLE, onDelete: Restrict. Same nullability
//     rationale as Fuel logs: an expense may or may not be paired
//     with a specific trip (a routine maintenance bill is not tied
//     to one trip; a toll paid mid-trip is). Restrict on the set
//     case protects per-trip cost reporting downstream.
//   - createdById — onDelete: Restrict, same audit-chain rationale
//     as every other createdBy FK in the schema.

/// Expense categories the CEO uses on paper today. Eight values
/// chosen because the existing handwritten expense ledger uses these
/// same categories; `OTHER` is the catch-all for genuine outliers
/// that do not fit elsewhere. Free-form category strings were
/// rejected at the iter-21 kickoff because they devolve into "Toll" /
/// "toll" / "TOLL" / "toll booth" variants of the same fact in the
/// database. If a ninth category emerges in practice, we add it as a
/// migration in a single line — the cost of an enum-add migration is
/// small. Documented in docs/glossary.md.
enum ExpenseCategory {
  MAINTENANCE
  REPAIR
  TOLL
  PARKING
  INSURANCE
  PERMIT
  FINE
  OTHER

  @@map("expense_category")
}

model ExpenseLog {
  id            String          @id @default(cuid())
  /// Nullable FK to Vehicle. A vehicle-agnostic expense (office
  /// stationery, the company's quarterly insurance premium) is a
  /// valid row with null vehicleId — same model docstring rationale.
  /// When set, onDelete: Restrict per ADR-0003 protects per-vehicle
  /// cost reporting. Indexed individually so list filters by
  /// vehicleId (the "expenses for this vehicle" UI query, exposed
  /// via the iter-21 list toolbar's text input and the future
  /// iter-23 cost report's deep-link) hit an index.
  vehicleId     String?
  vehicle       Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  /// Nullable FK to Trip. Same nullability rationale as Fuel logs —
  /// an expense may or may not be paired with a specific trip. When
  /// set, onDelete: Restrict per ADR-0003.
  tripId        String?
  trip          Trip?           @relation(fields: [tripId], references: [id], onDelete: Restrict)
  /// When the expense was incurred (UTC). Indexed `(date desc)` for
  /// the default list sort ("most recent expenses first"). ISO/UTC
  /// per CLAUDE.md; BS-calendar rendering arrives with the future
  /// <NepaliDate> component.
  date          DateTime
  /// Category bucket. See the ExpenseCategory enum docstring for
  /// the rationale behind the eight-value choice. Indexed so the
  /// list endpoint's `?category=<value>` filter hits an index.
  category      ExpenseCategory
  /// Amount in paisa (1 NPR = 100 paisa). Always integer minor
  /// units per CLAUDE.md §"Money & units". The display formatter
  /// renders e.g. 250000 paisa as "Rs. 2,500.00".
  amountPaisa   Int
  /// Vendor / payee — the shop, mechanic, toll booth, government
  /// office, or insurer who received the payment. Nullable; a
  /// genuine "unknown vendor" case exists when the operator is
  /// reconciling a bank statement against incomplete receipts.
  /// Tier 1 operational data — not PII per the glossary's caveat.
  vendor        String?
  /// Optional paper-receipt identifier. Nullable; not every
  /// expense has a receipt scan and the operator may key only the
  /// totals from a bank statement.
  receiptNumber String?
  /// Free-form operator notes. Tier 1 operational data today
  /// (see the model comment above for the contingency note).
  /// Nullable; the empty case is null rather than "".
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  /// References the User who created the expense-log record
  /// (ADR-0021 admin user). Audit field; Restrict because the
  /// expense-log's audit chain should remain intact for the row's
  /// lifetime.
  createdById   String
  createdBy     User            @relation("ExpenseLogCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  // Preventive-maintenance cost link (ADR-0037 c6, B4). A ServiceRecord may
  // reference this expense as the cost of a maintenance/repair service via its
  // nullable expenseLogId FK (onDelete: Restrict). This back-relation is the
  // only change to ExpenseLog — Prisma requires both sides of a relation; there
  // is NO new column on expense_log and no migration on existing rows. Because
  // the FK is Restrict, ExpenseLogsService.delete now maps the P2003 a referenced
  // expense raises to HTTP 409 (the latent-500 close its iter-22 docstring
  // anticipated for exactly this case).
  serviceRecords ServiceRecord[]

  @@index([vehicleId])
  @@index([tripId])
  @@index([category])
  @@index([date(sort: Desc)])
  @@index([createdById])
  @@map("expense_log")
}

// GPS telematics ingestion. Owned by apps/api/src/modules/telematics/
// per ADR-0001 (the feature module — ingestion endpoint, worker, read
// endpoints — lands in T3/T5; T2 ships ONLY this schema, its migration,
// the pino-redact egress additions, and the deferred Trip-delete
// resolution). First Phase-2 telematics aggregate per ADR-0029, and the
// FIRST PostGIS geometry in FleetCo. A GpsPing is one raw GPS fix
// reported for a vehicle; this is expected to be the highest-row-count
// table in the system, which is why the storage representation (below)
// is chosen deliberately before the first ping lands.
//
// Tier annotations per ADR-0013 + ADR-0027: the coordinate/movement
// columns (latitude, longitude, altitude, speed, heading) and the
// derived geometry are **Tier 5** — the most sensitive class, a raw
// location trail (ADR-0027 commitment 1 classes the whole
// lat/lon/altitude/speed/heading fix as Tier 5). They are never logged
// (the pino `redact` list in apps/api/src/app.module.ts gained the GPS
// attribute keys in this same slice, ADR-0027 commitment 5) and, once
// the ADR-0026 span-scrub seam exists, never exported in a span; raw
// pings are pruned after the retention window (the `traces-prune` job,
// T4). The FK/audit columns and `timestamp` are NOT Tier-5 location
// data — `timestamp` is the fix time, which travels with the Tier-5 fix
// but is not independently sensitive (ADR-0027 commitment 9), so it is
// not redacted (over-redacting operational time hides signal).
//
// Coordinate storage — the HYBRID representation (ADR-0029 commitment
// 8). The canonical coordinate columns are the Prisma-native `Float`
// `latitude` / `longitude`: Prisma reads and inserts them natively, so
// the high-frequency insert path and ordinary coordinate reads stay
// type-safe. Alongside them sits a Postgres
//   GENERATED ALWAYS AS (ST_SetSRID(ST_MakePoint(longitude, latitude), 4326)) STORED
// `geometry(Point, 4326)` column with a GIST index, used only by spatial
// queries (geofencing via ST_Contains / ST_DWithin — the derived read
// layer's first real spatial query, T5). The geometry column is
// declared `Unsupported("geometry(Point, 4326)")?` so Prisma tracks its
// existence for migrate-diffing but never tries to select or insert it
// (it is database-derived and so cannot drift from the floats — the
// same "drift is the failure mode" discipline the project enforces
// elsewhere); the generated-column definition and the GIST index are
// HAND-AUTHORED in the migration because Prisma's schema language
// expresses neither generated columns nor geometry types. Because the
// column is GENERATED ... STORED, inserts must NOT supply it — Prisma
// satisfies this for free by inserting only the Float columns. NOTE the
// `ST_MakePoint(longitude, latitude)` argument order: X,Y = lon,lat (the
// classic PostGIS foot-gun); the round-trip test
// (apps/api/test/gps-ping.schema.test.ts) asserts ST_X returns the
// longitude and ST_Y the latitude, the regression guard against a
// future ST_MakePoint(lat, lon) swap.
//
// CAUTION for future migrations: because the datamodel expresses
// `geometry` as a plain Unsupported type (Prisma models neither the
// GENERATED default nor the GIST index), `prisma migrate dev` diffs this
// against the DB and may emit a SPURIOUS step that DROPs
// `gps_ping_geometry_idx` or alters the generated default — that step
// MUST be removed. The established workflow (used for this migration) is
// `prisma migrate dev --create-only` then hand-edit, so the hand-authored
// geometry SQL is never clobbered. `prisma migrate status` (migrations vs
// DB) is the operative drift check and reports in-sync; the
// schema-datamodel-vs-DB diff intentionally shows the generated default +
// GIST index, which is the accepted, ADR-0029-documented hybrid cost.
//
// FK delete policy mirrors FuelLog (ADR-0029 commitment 7):
//   - vehicleId — required, onDelete: Restrict: a ping always belongs
//     to a vehicle; orphaning it would corrupt per-vehicle route
//     reconstruction.
//   - tripId — nullable, onDelete: Restrict: collection is scoped to
//     on-trip windows (ADR-0027 c2) so most pings carry a trip, but a
//     fix captured at a shift boundary may not; when set, Restrict
//     protects per-trip route reconstruction exactly as it protects
//     per-trip fuel cost. This FK makes Trip a referenced aggregate,
//     which is what makes the deferred TripsService.delete P2003 -> 409
//     mapping due — resolved in this same slice.
//   - createdById — required, onDelete: Restrict to User, filled from
//     the authenticated principal (ADR-0021); the audit anchor for who
//     submitted the ping.

model GpsPing {
  id          String                                @id @default(cuid())
  /// FK to Vehicle. Indexed individually so list filters by vehicleId
  /// (the "trace for this vehicle" query) hit an index. onDelete:
  /// Restrict per ADR-0029 commitment 7 — a ping always belongs to a
  /// vehicle and orphaning it would corrupt per-vehicle route history.
  vehicleId   String
  vehicle     Vehicle                               @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  /// Nullable FK to Trip. Collection is scoped to on-trip windows
  /// (ADR-0027 c2), so most pings carry a trip; a fix captured at a
  /// shift boundary may not. When set, onDelete: Restrict protects
  /// per-trip route reconstruction — and makes Trip a referenced
  /// aggregate (the FK that makes the deferred TripsService.delete
  /// P2003 -> 409 resolution due, landed in this slice).
  tripId      String?
  trip        Trip?                                 @relation(fields: [tripId], references: [id], onDelete: Restrict)
  /// Tier 5 per ADR-0027 — raw GPS latitude (WGS84, decimal degrees).
  /// Canonical coordinate column (Prisma-native Float; the geometry is
  /// derived from it). Never logged (pino redact) and, once the
  /// ADR-0026 span-scrub seam exists, never exported in a span; raw
  /// pings are pruned after the retention window (traces-prune, T4).
  latitude    Float
  /// Tier 5 per ADR-0027 — raw GPS longitude (WGS84, decimal degrees).
  /// Canonical coordinate column; never logged / never span-exported;
  /// pruned after the retention window. NOTE the geometry derives as
  /// ST_MakePoint(longitude, latitude) — longitude is X, latitude is Y.
  longitude   Float
  /// Tier 5 per ADR-0027 — altitude in meters above the WGS84 ellipsoid.
  /// Nullable (not every fix reports altitude). Never logged / never
  /// span-exported; pruned after the retention window.
  altitude    Float?
  /// Tier 5 per ADR-0027 — ground speed in meters per second. Nullable.
  /// Movement data travels with the location fix and is equally
  /// sensitive. Never logged / never span-exported; pruned after the
  /// retention window.
  speed       Float?
  /// Tier 5 per ADR-0027 — heading / course over ground in degrees
  /// (0–360, clockwise from true north). Nullable. Never logged / never
  /// span-exported; pruned after the retention window.
  heading     Float?
  /// The instant the fix was captured by the device (UTC). Indexed
  /// `(timestamp desc)` for recency queries. ISO/UTC per CLAUDE.md. NOT
  /// Tier-5 location data per ADR-0027 commitment 9: the fix time
  /// travels with the Tier-5 fix but is not independently sensitive, so
  /// it is not redacted (over-redacting operational time hides signal).
  timestamp   DateTime
  /// Tier 5 per ADR-0027 — PostGIS geometry(Point, 4326), GENERATED
  /// ALWAYS AS (ST_SetSRID(ST_MakePoint(longitude, latitude), 4326))
  /// STORED with a GIST index, both HAND-AUTHORED in the migration
  /// (Prisma expresses neither). Declared Unsupported so Prisma tracks
  /// it for migrate-diff but never selects/inserts it; the database
  /// derives it from latitude/longitude so it cannot drift. Used only
  /// by spatial queries (geofencing, T5). Same egress rules as the raw
  /// coordinates: never logged / never span-exported; pruned with the
  /// raw fix after the retention window.
  geometry    Unsupported("geometry(Point, 4326)")?
  createdAt   DateTime                              @default(now())
  updatedAt   DateTime                              @updatedAt
  /// References the User who submitted the ping (ADR-0021 authenticated
  /// principal). Audit field; Restrict because the ping's audit chain
  /// should remain intact for the row's lifetime.
  createdById String
  createdBy   User                                  @relation("GpsPingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([vehicleId])
  @@index([tripId])
  @@index([timestamp(sort: Desc)])
  @@index([createdById])
  @@map("gps_ping")
}

// Geofences module. Owned by apps/api/src/modules/geofences/ per ADR-0001
// (the feature module — service, controller, RBAC, web UI, Leaflet editor —
// lands in G2–G5; G1 ships ONLY this schema, its hand-authored migration,
// the test/db.ts truncate entry, and the round-trip schema test). First
// Phase-2 geofence-configuration aggregate per ADR-0030, and the FIRST
// PostGIS geometry(Polygon, 4326) in FleetCo (GpsPing T2 stored the first
// Point). A Geofence is a company-defined boundary — the depot yard, a
// customer site, or a route corridor — that the telematics derived-read
// layer (ADR-0029 T5) classifies a vehicle's latest fix against.
//
// Tier annotations per ADR-0013 + ADR-0027 c6: a geofence is Tier 3
// operational CONFIGURATION — a company asset like a Job record, NOT the
// Tier-5 location trail it is checked against. So its columns carry Tier-3
// marks and — unlike GpsPing's Tier-5 coordinates — NO pino-redact or
// span-scrub entries are added (over-redacting operational config hides
// signal; ADR-0030 c7 makes this explicit, clarifying ADR-0027 c5's
// "geofence polygon geometry" hedge as span-scoped, not config-scoped).
//
// Polygon storage — the HYBRID representation (ADR-0030 commitment 1),
// extending ADR-0029 c8's Point hybrid to a Polygon with ONE structural
// change: a polygon has no scalar canonical form, so the geometry derives
// from a canonical TEXT column (boundaryWkt) rather than from scalar floats.
// boundaryWkt is the Prisma-native canonical boundary — a closed WGS84 ring
// as POLYGON((lon lat, ...)) WKT, the exact representation
// telematics.schemas.ts already parses, so a stored fence and a T5
// query-param fence are byte-identical WKT and classify identically.
// Alongside it sits a Postgres
//   GENERATED ALWAYS AS (ST_GeomFromText("boundaryWkt", 4326)) STORED
// geometry(Polygon, 4326) column with a GIST index, used only by spatial
// queries (ST_Contains / ST_DWithin). ST_GeomFromText(text, 4326) — the
// two-arg form with an explicit SRID — is IMMUTABLE in PostGIS, which is
// what lets it drive a GENERATED ... STORED column (G1 verifies this against
// the CI-pinned postgis/postgis:16-3.5). The geometry column is declared
// Unsupported("geometry(Polygon, 4326)")? so Prisma tracks it for
// migrate-diffing but never selects or inserts it (the database derives it
// from boundaryWkt, so it cannot drift); the generated-column definition and
// the GIST index are HAND-AUTHORED in the migration because Prisma's schema
// language expresses neither. Because the column is GENERATED ... STORED,
// inserts must NOT supply it — Prisma satisfies this for free by inserting
// only boundaryWkt.
//
// CAUTION for future migrations (same as GpsPing): because geometry is a
// plain Unsupported type (Prisma models neither the GENERATED default nor
// the GIST index), prisma migrate dev may emit a SPURIOUS step that DROPs
// geofence_geometry_idx or alters the generated default — that step MUST be
// removed. The established workflow (used here) is migrate dev --create-only
// then hand-edit, so the hand-authored SQL is never clobbered. prisma
// migrate status is the operative drift check and reports in-sync; the
// schema-datamodel-vs-DB diff intentionally shows the generated default +
// GIST index, the accepted ADR-0030 hybrid cost.
//
// Validity is enforced in three layers (ADR-0030 c2): (a) Zod vertex checks
// in the G2 service (reusing T5's parser), (b) the generated column's
// parse-time rejection of structurally-broken WKT (ST_GeomFromText throws),
// and (c) a service-level ST_IsValid gate against self-intersecting/bowtie
// rings (G2). G1 ships the storage; the round-trip schema test pins that a
// valid ring round-trips at SRID 4326 with vertex order preserved and that a
// bowtie ring stores but reports ST_IsValid = false (the hazard G2 gates on).
//
// FK delete policy (ADR-0030 c4):
//   - customerId — NULLABLE, onDelete: Restrict to Customer. A CUSTOMER_SITE
//     fence belongs to a Customer; DEPOT and ROUTE_CORRIDOR fences have
//     customerId = null. The type/ownership invariant (CUSTOMER_SITE requires
//     non-null, the others null) is a G2 service/Zod .superRefine, NOT a DB
//     constraint here. Restrict matches the house posture, and
//     CustomersService.delete's EXISTING P2003 -> 409 arm covers this new
//     referencer for free (no CustomersService change in G2).
//   - createdById — required, onDelete: Restrict to User, filled from the
//     authenticated principal (ADR-0021); the audit anchor for who created
//     the fence.

enum GeofenceType {
  DEPOT
  CUSTOMER_SITE
  ROUTE_CORRIDOR

  @@map("geofence_type")
}

model Geofence {
  id          String                                  @id @default(cuid())
  /// Tier 3 per ADR-0013 — human-readable geofence name.
  name        String
  /// Tier 3 per ADR-0013 — DEPOT / CUSTOMER_SITE / ROUTE_CORRIDOR.
  type        GeofenceType
  /// Tier 3 per ADR-0013 — canonical polygon boundary (closed WGS84 ring as
  /// WKT); the geometry column is GENERATED from this, so it cannot drift.
  boundaryWkt String
  /// Tier 3 per ADR-0013 — PostGIS geometry(Polygon,4326), GENERATED ALWAYS
  /// AS (ST_GeomFromText("boundaryWkt", 4326)) STORED with a GIST index, both
  /// HAND-AUTHORED in the migration (Prisma expresses neither). Declared
  /// Unsupported so Prisma tracks it for migrate-diff but never
  /// selects/inserts it; derives from boundaryWkt so it cannot drift. Used
  /// only by spatial queries.
  geometry    Unsupported("geometry(Polygon, 4326)")?
  /// Tier 3 per ADR-0013 — owning Customer for CUSTOMER_SITE fences; null for
  /// DEPOT/ROUTE_CORRIDOR.
  customerId  String?
  customer    Customer?                               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdAt   DateTime                                @default(now())
  updatedAt   DateTime                                @updatedAt
  /// References the User who created the geofence (ADR-0021 authenticated
  /// principal). Audit field; Restrict because the fence's audit chain should
  /// remain intact for the row's lifetime.
  createdById String
  createdBy   User                                    @relation("GeofenceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([customerId])
  @@index([createdById])
  @@map("geofence")
}

// Preventive-maintenance scheduling. Owned by apps/api/src/modules/maintenance/
// per ADR-0001. First Phase-3 / Program-B maintenance aggregate per ADR-0037,
// pulled forward under the ADR-0025 ahead-of-gate pattern (ADR-0037 §"Phase
// mismatch"), and the consumer of the engine-hours dimension ADR-0036 shipped
// (B1/B2). Preventive maintenance is modeled as a dedicated TWO-table aggregate
// anchored on the central Vehicle (ADR-0003) — a ServiceSchedule (a recurring
// maintenance interval for a vehicle) and a ServiceRecord (a completed service
// event, the history) — rather than columns on Vehicle, because the cardinality
// is wrong for columns: a vehicle has MANY concurrent schedules and an
// UNBOUNDED, growing history (ADR-0037 c1, the deliberate contrast with
// ADR-0036's cardinality-one engine-hours columns). The dedicated-aggregate
// choice mirrors ADR-0030's Geofence reasoning and the Phase-1 aggregate CRUD
// convention.
//
// Tier annotations per ADR-0013: every field here is Tier 3 operational
// business data (interval definitions, meter readings, service dates,
// free-text names/notes) — a company asset like a Job record. There is NO PII
// (no person names, no contact info) and NO Tier-5 location data, so — unlike
// GpsPing's coordinates — NO new pino-redact or span-scrub entries are added
// (over-redacting Tier 3 operational data hides the signal pino is meant to
// surface). `notes` is free-form operator commentary; the future write-path UI
// directs operators not to enter PII there.
//
// FK delete policy (ADR-0037 c1): both ServiceSchedule.vehicleId and
// ServiceRecord.vehicleId are onDelete: Restrict (the house posture —
// FuelLog/ExpenseLog/GpsPing all Restrict), so a vehicle with maintenance
// history cannot be silently deleted; VehiclesService.delete's EXISTING P2003
// → 409 arm covers the new referencers with no change. ServiceRecord's nullable
// serviceScheduleId FK is also onDelete: Restrict — a schedule with recorded
// history cannot be silently deleted (its ServiceSchedulesService.delete maps
// the P2003 → 409, mirroring CustomersService). createdById follows the same
// Restrict audit-chain posture as every other createdBy FK in the schema.

// The interval dimension a service schedule is measured in (ADR-0037 c2). One
// discriminator + one integer intervalValue in that dimension's minor units:
//   - DISTANCE_KM   — kilometers, against Vehicle.odometerCurrentKm (trucks/tippers)
//   - ENGINE_HOURS  — integer TENTHS OF AN HOUR, against Vehicle.engineHoursCurrent
//                     (ADR-0036; the equipment half) — a 250-hour interval stores
//                     as 2500, never a float (the integer-minor-units rule)
//   - CALENDAR_DAYS — days, against the wall clock (annual/periodic inspections)
// One discriminated enum is preferred over three nullable type-specific columns
// because it is unambiguous and makes an impossible type a compile error (the
// same reasoning ADR-0036 used for meterType, ADR-0030 for GeofenceType).
enum ServiceIntervalType {
  DISTANCE_KM
  ENGINE_HOURS
  CALENDAR_DAYS

  @@map("service_interval_type")
}

// A schedule can be paused without deleting it (ADR-0037 c8f, mirroring
// CustomerStatus). An INACTIVE schedule keeps its history and anchor but is
// excluded from the due/overdue surface (B4) by the read layer.
enum ServiceScheduleStatus {
  ACTIVE
  INACTIVE

  @@map("service_schedule_status")
}

model ServiceSchedule {
  id                     String                @id @default(cuid())
  /// FK to Vehicle (the anchor, ADR-0003/0037 c1). Indexed individually so the
  /// "schedules for this vehicle" query hits an index. onDelete: Restrict — a
  /// vehicle with schedules cannot be deleted (VehiclesService's existing P2003
  /// → 409 arm covers it).
  vehicleId              String
  vehicle                Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  /// Tier 3 per ADR-0013 — human-readable schedule name, free text (ADR-0037
  /// c8b: services are open-ended/manufacturer-specific, so a free-text name
  /// over a closed enum), e.g. "250-hour oil & filter service". Unique per
  /// vehicle (see @@unique) so the same schedule is not defined twice on one
  /// asset; a duplicate surfaces as P2002 → 409 with field "name".
  name                   String
  /// Tier 3 per ADR-0013 — optional longer description of the work. Nullable.
  description            String?
  /// Tier 3 per ADR-0013 — which meter dimension this interval is measured in.
  intervalType           ServiceIntervalType
  /// Tier 3 per ADR-0013 — interval length as an INTEGER in the type's minor
  /// units (km / tenths-of-an-hour / days), never a float (ADR-0037 c2, the
  /// integer-minor-units rule). A 250-hour ENGINE_HOURS interval stores as 2500.
  intervalValue          Int
  status                 ServiceScheduleStatus @default(ACTIVE)
  /// Tier 3 per ADR-0013 — last-service anchor (ADR-0037 c4): when the schedule
  /// was last serviced (UTC). "Next due" is DERIVED from the anchor + interval,
  /// not stored. Seeded at create (operator-supplied or now()); advanced forward
  /// on a ServiceRecord write inside one $transaction in B4.
  lastServiceAt          DateTime
  /// Tier 3 per ADR-0013 — odometer reading (km) captured at the last service.
  /// Nullable: null for an ENGINE_HOURS/CALENDAR_DAYS schedule. Seeded from the
  /// vehicle's current odometer for a DISTANCE_KM schedule (ADR-0037 c4).
  lastServiceOdometerKm  Int?
  /// Tier 3 per ADR-0013 — engine-hours reading (integer TENTHS OF AN HOUR)
  /// captured at the last service. Nullable: null for a DISTANCE_KM/CALENDAR_DAYS
  /// schedule, or for an ENGINE_HOURS schedule on a vehicle whose
  /// engineHoursCurrent is still null. Seeded from the vehicle's current hours
  /// for an ENGINE_HOURS schedule (ADR-0037 c4).
  lastServiceEngineHours Int?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  /// References the User who created the schedule (ADR-0021). Audit field;
  /// Restrict so the schedule's audit chain stays intact for its lifetime.
  createdById            String
  createdBy              User                  @relation("ServiceScheduleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  serviceRecords ServiceRecord[]

  @@unique([vehicleId, name])
  @@index([vehicleId])
  @@index([status])
  @@index([createdById])
  @@map("service_schedule")
}

model ServiceRecord {
  id                String           @id @default(cuid())
  /// FK to Vehicle. Indexed individually so the "service history for this
  /// vehicle" query hits an index. onDelete: Restrict (house posture).
  vehicleId         String
  vehicle           Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  /// Nullable FK to ServiceSchedule (ADR-0037: an ad-hoc / one-off service has
  /// no schedule). When set, onDelete: Restrict protects the linkage — a
  /// schedule with recorded history cannot be silently deleted
  /// (ServiceSchedulesService.delete maps the P2003 → 409). A recorded service
  /// against a schedule advances that schedule's anchor (the $transaction lands
  /// in B4; B3 records are plain inserts).
  serviceScheduleId String?
  serviceSchedule   ServiceSchedule? @relation(fields: [serviceScheduleId], references: [id], onDelete: Restrict)
  /// Nullable FK to the ExpenseLog that records this service's COST (ADR-0037
  /// c6, B4). The authoritative maintenance spend lives in exactly ONE place —
  /// an ExpenseLog row with category MAINTENANCE/REPAIR and its amountPaisa —
  /// and a ServiceRecord REFERENCES that row rather than copying the amount
  /// (there is deliberately no amountPaisa column here). Nullable because (a) a
  /// warranty service has no cost and (b) a service may be recorded before its
  /// invoice is keyed in. onDelete: Restrict so a linked expense cannot be
  /// silently deleted out from under the record (ExpenseLogsService.delete maps
  /// the resulting P2003 → 409). The FK lives on this NEW model pointing at the
  /// shipped ExpenseLog, so ExpenseLog gains only the Prisma back-relation —
  /// no data column, no migration on existing expense rows. A service-layer
  /// consistency check (ServiceRecordsService) requires the referenced expense
  /// to be MAINTENANCE/REPAIR and on the same vehicle as the record.
  expenseLogId      String?
  expenseLog        ExpenseLog?      @relation(fields: [expenseLogId], references: [id], onDelete: Restrict)
  /// When the service was performed (UTC). Indexed `(performedAt desc)` for the
  /// default "most recent service first" list sort. ISO/UTC per CLAUDE.md;
  /// rendered Bikram Sambat on the web side (B5).
  performedAt       DateTime
  /// Tier 3 per ADR-0013 — odometer reading (km) at service. Nullable (a
  /// calendar or hours service may not capture it). Integer per the odometer
  /// convention.
  odometerKm        Int?
  /// Tier 3 per ADR-0013 — engine-hours reading (integer TENTHS OF AN HOUR) at
  /// service. Nullable. Integer minor units, never a float (the litersMl /
  /// ADR-0036 precedent).
  engineHours       Int?
  /// Tier 3 per ADR-0013 — free-form operator notes. Not PII. Nullable; the
  /// empty case is null rather than "".
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  /// References the User who recorded the service (ADR-0021). Audit field;
  /// Restrict so the record's audit chain stays intact for its lifetime.
  createdById       String
  createdBy         User             @relation("ServiceRecordCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([vehicleId])
  @@index([serviceScheduleId])
  @@index([expenseLogId])
  @@index([performedAt(sort: Desc)])
  @@index([createdById])
  @@map("service_record")
}
