# FleetCo API test environment.
# Copy this file to `.env.test` (which is gitignored) and adjust the
# Postgres port to match your local docker-compose setup. The test
# Postgres is the same instance as your dev Postgres but a separate
# database (`fleetco_test`) so test runs do not touch dev data.
#
# CI does not use this file; the GitHub Actions workflow injects the
# same variables via the `services: postgres` block and the env: on
# the test step. See ADR-0023 §6 and `.github/workflows/ci.yml`.
#
# First-time local setup (one-off, after the docker-compose Postgres
# is up):
#
#   docker exec -i fleetco-bootstrap-v3-postgres-1 \
#     psql -U fleetco -d fleetco -c 'CREATE DATABASE fleetco_test;'
#
# The Prisma migrations are then applied automatically by Vitest's
# global-setup hook (apps/api/test/global-setup.ts) on the first
# `pnpm --filter @fleetco/api test` invocation.

NODE_ENV=test

# Required. Adjust the port to match the POSTGRES_PORT override in your
# repo-root .env (defaults to 5432; this developer's machine uses 55432
# because of a sibling-Docker-project collision).
DATABASE_URL=postgresql://fleetco:fleetco@localhost:5432/fleetco_test?schema=public

# Required. Same port-override note as DATABASE_URL.
REDIS_URL=redis://localhost:6379

# 32-byte placeholder; test-only, never reused outside tests. The env
# schema only enforces minimum length here.
BETTER_AUTH_SECRET=test-secret-32-bytes-minimum-aaaaaa

BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=fatal
