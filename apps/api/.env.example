# FleetCo API local environment.
# Copy this file to .env (which is gitignored) and fill in real values.
# Tier 1 secrets (e.g. SENTRY_DSN, BETTER_AUTH_SECRET, ADMIN_PASSWORD, real
# DATABASE_URL passwords) per ADR-0013 must never appear in any committed file.

NODE_ENV=development
PORT=3001

# Optional. When unset, Sentry init no-ops and the process emits no
# Sentry telemetry. In production, this is the project's DSN from the
# Sentry dashboard.
SENTRY_DSN=

# Optional (ADR-0024). The full OTLP/HTTP traces endpoint, e.g.
# https://collector.example.com/v1/traces. When unset, no OTLP exporter is
# built and the API ships no OTLP telemetry (the Phase-1 default); when set,
# spans fan out to both Sentry and this collector. A tracing backend and its
# sampling policy are chosen in Phase 2, so this stays blank for now.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional. Defaults to 'info'. One of: fatal, error, warn, info, debug,
# trace.
LOG_LEVEL=info

# Required. Postgres connection string. The username/password below are
# Tier 4 dev placeholders matching docker-compose.yml. Real production
# credentials are Tier 1 and live in the secret store named by the
# eventual deployment ADR (ADR-0014, reserved).
#
# If you overrode POSTGRES_PORT in the repo-root .env to avoid a sibling
# Docker project's port collision, update the host port below to match
# (e.g. localhost:55432). See docs/runbook/dev-setup.md.
DATABASE_URL=postgresql://fleetco:fleetco@localhost:5432/fleetco?schema=public

# Required. Redis connection string. Tier 4 in dev (placeholder), Tier 1
# in production. Same override note as DATABASE_URL applies if you set
# REDIS_PORT in the repo-root .env.
REDIS_URL=redis://localhost:6379

# Required. better-auth session-signing secret. Tier 1 per ADR-0013 —
# never commit a real value here; this file only documents the variable.
# Minimum 32 bytes (256 bits). Generate locally with:
#   pnpm --filter @fleetco/api run auth:secret
# In production this comes from the secret store named by ADR-0014.
BETTER_AUTH_SECRET=replace-with-32-byte-secret-from-auth:secret

# Required. The API's public base URL. In local dev this matches the API's
# own PORT; if you overrode PORT to 3011, set this to http://localhost:3011.
# better-auth uses this for cookie scoping and origin checks.
BETTER_AUTH_URL=http://localhost:3001

# Optional. Comma-separated allowlist of origins that may post credentials
# to the API. Defaults to http://localhost:3000 (the apps/web dev server).
CORS_ORIGIN=http://localhost:3000

# Optional at API runtime; required when running `pnpm db:seed`.
# ADMIN_EMAIL is Tier 2 PII per ADR-0013 — the founder's email.
# ADMIN_PASSWORD is Tier 1 per ADR-0013 — the founder's credential.
# Set both in your local .env (never here) before running the seed script.
ADMIN_EMAIL=admin@fleetco.local
ADMIN_PASSWORD=

# Optional. Transactional-email provider API key for the reminder-delivery
# channel (ADR-0038, Program C). Tier 1 secret per ADR-0013 — never commit a
# real value here; this file only documents the variable. In production it
# comes from the secret store named by ADR-0014. When unset (the dev/test/CI
# default) the API boots normally and the reminder channel cannot send — it
# only delivers from production with this key plus a verified sending domain.
RESEND_API_KEY=

# Optional at boot; REQUIRED before issuing a real invoice (ADR-0039, Program D).
# FleetCo's OWN supplier PAN/VAT number — the seller's tax identity printed on
# every tax invoice, distinct from a customer's PAN. Operator-supplied; this file
# only documents the variable (never a fabricated PAN). When unset, the API boots
# normally but invoice issue() refuses with a clear 422 until it is configured.
# ⚠️ PROPOSED / operator-verify: the supplier PAN and the full IRD-required
# invoice field set must be confirmed with the operator's accountant (ADR-0039 c9).
INVOICE_SUPPLIER_PAN=

# Optional. FleetCo's OWN supplier NAME printed on the invoice header beside the
# PAN (ADR-0039, Program D). Unlike the PAN this has a safe default ("FleetCo"),
# so leaving it blank never blocks issuing — set it to the exact registered
# business name once confirmed with the operator's accountant.
INVOICE_SUPPLIER_NAME=

# Cloudflare R2 object storage for the issued invoice PDF (ADR-0039 commitment 7 —
# the FIRST in-app R2 use; ADR-0014 c6). All four are operator-supplied; this file
# only documents the variables. When ANY is unset (the dev/test/CI default) the
# API boots normally, uses an in-memory mock store, and invoice issue() refuses
# with a clear 422 until R2 is configured — so the API never reaches R2 outside
# production. R2_ACCESS_KEY_ID and R2_SECRET_ACCESS_KEY are Tier 1 secrets per
# ADR-0013 — NEVER commit a real value here; in production they come from the
# secret store named by ADR-0014. R2_ENDPOINT is the S3 API endpoint from the
# Cloudflare dashboard (e.g. https://<accountid>.r2.cloudflarestorage.com).
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Optional. DeepSeek hosted-LLM API key for the AI chat agent (ADR-0043).
# Tier 1 secret per ADR-0013 — never commit a real value here; this file only
# documents the variable. In production it comes from the secret store named
# by ADR-0014. When unset (the dev/test/CI default) the API boots normally and
# the agent module binds MockLlmClient, so no request ever leaves the box —
# and unsetting the key in production is the agent's kill switch (ADR-0043 c2).
DEEPSEEK_API_KEY=

# Optional. The DeepSeek model the agent requests (defaults to
# deepseek-v4-flash; the legacy deepseek-chat / deepseek-reasoner names
# deprecate 2026-07-24). Tier-4 config — override only to track a provider
# model rename without a deploy.
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Agent document extraction (ADR-0044 Box B: self-hosted OCR) ------------
# The OCR sidecar's OpenAI-compatible base URL. OPTIONAL — unset (the default)
# binds the no-network MockVisionExtractor: attachment turns degrade to an
# honest "extraction is not configured" notice and no image is processed.
# Local dev under Docker Model Runner:
#   AGENT_OCR_URL=http://localhost:12434/engines/llama.cpp/v1
AGENT_OCR_URL=
# The OCR model id the sidecar serves. Defaults to the community GGUF quant
# the V0 eval pinned (ADR-0044 Box B); a swap is an env edit.
#AGENT_OCR_MODEL=huggingface.co/sahilchachra/unlimited-ocr-gguf:Q4_K_M

# --- WhatsApp agent channel (Twilio — ADR-0046) ------------------------------
# ALL optional. When the TWILIO_* group is unset (the dev/test/CI default) the
# api binds MockWhatsAppSender and the inbound webhook fails closed (503) — the
# channel is OFF. TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN are Tier 1 secrets per
# ADR-0013 — never commit real values; production values live only in the
# on-box secret file, and activation is docs/runbook/whatsapp-operations.md's
# procedure. TWILIO_WHATSAPP_FROM is the whatsapp:+<E164> sender;
# TWILIO_WEBHOOK_URL is the exact public webhook URL the signature guard pins
# byte-for-byte (scheme, host, path).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WEBHOOK_URL=

# Optional. The admin web's public base URL used to build absolute deep-links
# in agent WhatsApp replies (ADR-0046). In local dev: http://localhost:3000.
# When unset the renderer simply omits the deep-link.
WEB_PUBLIC_URL=
